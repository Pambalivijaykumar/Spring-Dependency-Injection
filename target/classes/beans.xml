<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">



<bean  id="user" class="com.module.User" autowire="constructor">
  <constructor-arg value="Vijay"></constructor-arg>
  <constructor-arg value="22"></constructor-arg>
  <constructor-arg ref="address"></constructor-arg>
</bean>


<bean id="address" class="com.module.Address">
	<property name="village" value="Hyderabad"/>
	<property name="zipCode" value="12345"/>
</bean>


<bean id="address" class="com.module.Address">
	<constructor-arg value="Medchal"></constructor-arg>
	<constructor-arg value="500078"></constructor-arg>
</bean>


</beans>
